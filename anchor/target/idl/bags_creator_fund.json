          "index": false
        }
      ]
    },
    {
      "name": "TreasuryWithdrawal",
      "fields": [
        {
          "name": "project",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "creator",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "amountLamports",
          "type": "u64",
          "index": false
        },
