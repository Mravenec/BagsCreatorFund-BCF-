{
  "version": "0.1.0",
  "name": "bags_creator_fund",
  "instructions": [
    {
      "name": "initializeProject",
      "docs": [
        "Step 1: Creator links their Bags token to create a project on-chain"
      ],
      "accounts": [
        {
          "name": "project",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "creator",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "tokenMint",
          "type": "publicKey"
        },
        {
          "name": "feeModeName",
          "type": "string"
        }
      ]
    },
    {
      "name": "createCampaign",
      "docs": [
        "Step 2: Create a funding campaign associated with the project token"
      ],
      "accounts": [
        {
          "name": "campaign",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "creator",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "prizeLamports",
          "type": "u64"
        },
        {
          "name": "positionPriceLamports",
          "type": "u64"
        },
        {
          "name": "tokensPerPosition",
          "type": "u64"
        },
        {
          "name": "durationSeconds",
          "type": "i64"
        },
        {
          "name": "title",
          "type": "string"
        },
        {
          "name": "description",
          "type": "string"
        }
      ]
    },
    {
      "name": "fundCampaign",
      "docs": [
        "Step 3: Creator deposits prize SOL into campaign account → activates it",
        "The campaign account itself acts as the vault (program-owned)"
      ],
      "accounts": [
        {
          "name": "campaign",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "creator",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "buyPosition",
      "docs": [
        "Web3 wallet user buys a specific position (00–99)"
      ],
      "accounts": [
        {
          "name": "campaign",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "buyer",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "positionIndex",
          "type": "u8"
        }
      ]
    },
    {
      "name": "recordExternalPayment",
      "docs": [
        "Record a CEX/external payment after creator verifies it off-chain",
        "The creator is the trusted authority for this — all actions are on-chain and visible",
        "In production: replace with oracle or ZK proof of payment"
      ],
      "accounts": [
        {
          "name": "campaign",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "authority",
          "isMut": false,
          "isSigner": true,
          "docs": [
            "Campaign creator authorizes this after verifying CEX payment off-chain"
          ]
        }
      ],
      "args": [
        {
          "name": "positionIndex",
          "type": "u8"
        },
        {
          "name": "payer",
          "type": "publicKey"
        }
      ]
    },
    {
      "name": "resolveCampaign",
      "docs": [
        "Resolve the campaign: derive winning position from Solana slot hash (deterministic, public)",
        "Formula: winning_position = u64::from_le_bytes(slot_hash[0..8]) % 20"
      ],
      "accounts": [
        {
          "name": "campaign",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "slotHashes",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "claimPrize",
      "docs": [
        "Winner claims their prize — all SOL in campaign account goes to them"
      ],
      "accounts": [
        {
          "name": "campaign",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "winner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "routeNoWinnerToTreasury",
      "docs": [
        "Route prize to project treasury when winning position was unclaimed"
      ],
      "accounts": [
        {
          "name": "campaign",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "withdrawTreasury",
      "docs": [
        "Creator withdraws from project treasury",
        "All withdrawals are emitted as events — fully transparent to community"
      ],
      "accounts": [
        {
          "name": "project",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "creator",
          "isMut": true,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "ProjectAccount",
      "docs": [
        "Creator's project account — links Bags token, holds treasury"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "creator",
            "type": "publicKey"
          },
          {
            "name": "tokenMint",
            "type": "publicKey"
          },
          {
            "name": "treasuryLamports",
            "type": "u64"
          },
          {
            "name": "totalEarned",
            "type": "u64"
          },
          {
            "name": "campaignCount",
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          },
          {
            "name": "feeModeName",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "CampaignAccount",
      "docs": [
        "Funding campaign — holds ALL SOL (acts as vault), tracks all positions"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "creator",
            "type": "publicKey"
          },
          {
            "name": "project",
            "type": "publicKey"
          },
          {
            "name": "tokenMint",
            "type": "publicKey"
          },
          {
            "name": "prizeLamports",
            "type": "u64"
          },
          {
            "name": "positionPriceLamports",
            "type": "u64"
          },
          {
            "name": "tokensPerPosition",
            "type": "u64"
          },
          {
            "name": "durationSeconds",
            "type": "i64"
          },
          {
            "name": "deadline",
            "type": "i64"
          },
          {
            "name": "createdAt",
            "type": "i64"
          },
          {
            "name": "status",
            "type": "u8"
          },
          {
            "name": "positionsFilled",
            "type": "u8"
          },
          {
            "name": "totalCollected",
            "type": "u64"
          },
          {
            "name": "treasuryContribution",
            "type": "u64"
          },
          {
            "name": "winningPosition",
            "type": "u8"
          },
          {
            "name": "hasWinner",
            "type": "bool"
          },
          {
            "name": "winner",
            "type": "publicKey"
          },
          {
            "name": "winningSlot",
            "type": "u64"
          },
          {
            "name": "campaignIndex",
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          },
          {
            "name": "positions",
            "type": {
              "array": [
                {
                  "defined": "PositionInfo"
                },
                20
              ]
            }
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "PositionInfo",
      "docs": [
        "One position in the funding round grid (00–99)"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "filled",
            "type": "bool"
          },
          {
            "name": "owner",
            "type": "publicKey"
          }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "ProjectCreated",
      "fields": [
        {
          "name": "creator",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "tokenMint",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "timestamp",
          "type": "i64",
          "index": false
        }
      ]
    },
    {
      "name": "CampaignCreated",
      "fields": [
        {
          "name": "campaign",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "creator",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "prizeLamports",
          "type": "u64",
          "index": false
        },
        {
          "name": "positionPriceLamports",
          "type": "u64",
          "index": false
        },
        {
          "name": "campaignIndex",
          "type": "u64",
          "index": false
        }
      ]
    },
