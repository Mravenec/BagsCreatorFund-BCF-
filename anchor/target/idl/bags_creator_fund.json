      "fields": [
        {
          "name": "campaign",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "deadline",
          "type": "i64",
          "index": false
        }
      ]
    },
    {
      "name": "PositionPurchased",
      "fields": [
        {
          "name": "campaign",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "positionIndex",
          "type": "u8",
          "index": false
        },
        {
          "name": "buyer",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "priceLamports",
          "type": "u64",
          "index": false
        },
        {
          "name": "tokensReceived",
          "type": "u64",
          "index": false
        }
      ]
    },
    {
      "name": "CampaignResolved",
      "fields": [
        {
          "name": "campaign",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "winningPosition",
          "type": "u8",
          "index": false
        },
        {
          "name": "hasWinner",
          "type": "bool",
          "index": false
        },
        {
          "name": "winner",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "totalPot",
