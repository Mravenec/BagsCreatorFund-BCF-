{
  "version": "1.0.0",
  "name": "bcf_core",
  "instructions": [
    {
      "name": "initializeRaffle",
      "accounts": [
        { "name": "raffle", "isMut": true, "isSigner": false },
        { "name": "vaultAccount", "isMut": true, "isSigner": false },
        { "name": "mint", "isMut": false, "isSigner": false },
        { "name": "creator", "isMut": true, "isSigner": true },
        { "name": "tokenProgram", "isMut": false, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false },
        { "name": "rent", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "prizeAmount", "type": "u64" },
        { "name": "ticketPrice", "type": "u64" },
        { "name": "duration", "type": "i64" },
        { "name": "description", "type": "string" },
        { "name": "donationAddress", "type": { "option": "publicKey" } }
      ]
    },
    {
      "name": "activateRaffle",
      "accounts": [
        { "name": "raffle", "isMut": true, "isSigner": false },
        { "name": "creator", "isMut": false, "isSigner": true },
        { "name": "vaultAccount", "isMut": true, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "buyTicket",
      "accounts": [
        { "name": "raffle", "isMut": true, "isSigner": false },
        { "name": "buyer", "isMut": true, "isSigner": true },
        { "name": "buyerTokenAccount", "isMut": true, "isSigner": false },
        { "name": "vaultAccount", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": [{ "name": "number", "type": "u8" }]
    },
    {
      "name": "settleRaffle",
      "accounts": [
        { "name": "raffle", "isMut": true, "isSigner": false },
        { "name": "randomnessAccount", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "claimUniversal",
      "accounts": [
        { "name": "raffle", "isMut": true, "isSigner": false },
        { "name": "claimant", "isMut": true, "isSigner": true },
        { "name": "vaultAccount", "isMut": true, "isSigner": false },
        { "name": "creatorTokenAccount", "isMut": true, "isSigner": false },
        { "name": "winnerTokenAccount", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "cancelRaffle",
      "accounts": [
        { "name": "raffle", "isMut": true, "isSigner": false },
        { "name": "creator", "isMut": true, "isSigner": true },
        { "name": "vaultAccount", "isMut": true, "isSigner": false },
        { "name": "creatorTokenAccount", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "assignTicketAdmin",
      "accounts": [
        { "name": "raffle", "isMut": true, "isSigner": false },
        { "name": "authority", "isMut": false, "isSigner": true }
      ],
      "args": [
        { "name": "buyer", "type": "publicKey" },
        { "name": "number", "type": "u8" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "Raffle",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "creator", "type": "publicKey" },
          { "name": "prizeAmount", "type": "u64" },
          { "name": "ticketPrice", "type": "u64" },
          { "name": "startTime", "type": "i64" },
          { "name": "endTime", "type": "i64" },
          { "name": "expiryTime", "type": "i64" },
          { "name": "createdAt", "type": "i64" },
          { "name": "status", "type": { "defined": "RaffleStatus" } },
          { "name": "description", "type": "string" },
          { "name": "donationAddress", "type": { "option": "publicKey" } },
          { "name": "totalTicketsSold", "type": "u64" },
          { "name": "collectedFunds", "type": "u64" },
          { "name": "winningNumber", "type": { "option": "u8" } },
          { "name": "bump", "type": "u8" },
          { "name": "vaultBump", "type": "u8" },
          { "name": "slots", "type": { "array": [{ "option": "publicKey" }, 100] } }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "RaffleStatus",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "WaitingDeposit" },
          { "name": "Active" },
          { "name": "Resolved" },
          { "name": "Closed" },
          { "name": "Cancelled" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "InsufficientPrizeDeposit", "msg": "Insufficient prize deposit in vault." },
    { "code": 6001, "name": "RaffleNotActive", "msg": "Raffle is not active." },
    { "code": 6002, "name": "InvalidNumberSelection", "msg": "Invalid slot or already occupied." },
    { "code": 6003, "name": "RaffleStillOngoing", "msg": "Raffle still ongoing." },
    { "code": 6004, "name": "RaffleNotResolved", "msg": "Raffle not resolved." },
    { "code": 6005, "name": "UnauthorizedClaimant", "msg": "Unauthorized claimant." },
    { "code": 6006, "name": "RaffleNotCancellable", "msg": "Raffle cannot be cancelled in current state." }
  ]
}
